PORT=3001

# Signing key for login tokens (HS256). Generate with: openssl rand -base64 48
# Use a DIFFERENT secret per environment (local vs Render/production).
JWT_SECRET=replace-with-openssl-rand-base64-48
JWT_EXPIRES_IN=8h

# Local SQLite (default when DATABASE_URL is unset)
DATABASE_PATH=./data/warehouse.db

# Neon Postgres — when set, SQLite is skipped (use pooled connection string)
# DATABASE_URL=postgresql://USER:PASS@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
